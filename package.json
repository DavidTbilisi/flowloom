{
  "name": "flowloom",
  "version": "0.2.0",
  "description": "Text-first systems-thinking studio — stocks, flows, feedback loops, animated. AI-native by design.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:all": "vitest run && playwright test",
    "gen:examples": "vite-node scripts/gen-examples.ts",
    "gen:stress": "vite-node scripts/gen-stress.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
